# Default: Groq (GRATIS, gak perlu kartu kredit) - https://console.groq.com/keys
PROVIDER=groq
GROQ_API_KEY=

# Kalau mau pakai Anthropic (berbayar, kualitas lebih tinggi) ganti PROVIDER=anthropic
# dan isi key di bawah - https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Meilisearch
MEILI_HOST=http://127.0.0.1:7700
MEILI_MASTER_KEY=masterKeyGantiIni

# Server
PORT=4000
